{
  "name": "revou-week-7-typescript-seoul",
  "version": "1.0.0",
  "description": "RevoU Week 7 — TypeScript course demo files (Seoul cohort)",
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.ts"],
    "verbose": true,
    "transform": {
      "^.+\\.ts$": ["ts-jest", { "tsconfig": "tsconfig.test.json" }]
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luthfihariz/revou-week-7-typescript-seoul.git"
  },
  "license": "ISC",
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^6.0.3"
  }
}
